FROM python:3.12-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy project files (uv.lock optional; generated by `uv lock` and recommended
# to commit — uv sync will resolve fresh if it's absent)
COPY services/queryA/pyproject.toml services/queryA/uv.lock* ./

# Install dependencies
RUN uv sync

# Copy source code and shared module
COPY services/queryA/src/ ./services/queryA/src/
COPY shared/ ./shared/

# Expose the port Cloud Run will listen on
ENV PORT 8080
ENV PYTHONPATH=/app/services/queryA/src:/app

WORKDIR /app/services/queryA/src

# Run the FastAPI application
CMD /app/.venv/bin/uvicorn main:app --host 0.0.0.0 --port $PORT
